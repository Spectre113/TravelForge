# Environment variables for Budget Compass Backend

# Server configuration
# Backend HTTP port
PORT=5000

# Application environment:
# use "development" for local development,
# use "production" in Docker/Kubernetes runtime
NODE_ENV=development

# JWT secret used for signing tokens.
# Do not commit a real value to git.
# Replace with a strong random string in local/prod environments.
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# GigaChat OAuth client ID.
# Keep the real value only in local secrets / Kubernetes Secret / CI secrets.
GIGACHAT_CLIENT_ID=your-gigachat-client-id

# GigaChat OAuth client secret.
# Keep the real value only in local secrets / Kubernetes Secret / CI secrets.
# Use the raw client secret value here, not a pre-built Base64 authorization string.
GIGACHAT_SECRET=your-gigachat-secret

# GigaChat OAuth scope
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# GigaChat model name used for chat requests
GIGACHAT_MODEL=GigaChat

# GigaChat request timeout in seconds
GIGACHAT_TIMEOUT=60

# TLS certificate verification for GigaChat:
# 1 = verify certificate (recommended, default)
# 0 = disable verification (ONLY for local non-production debugging)
GIGACHAT_TLS_VERIFY=1

# CORS: comma-separated list of allowed frontend origins
# Default: http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging level: trace | debug | info | warn | error
LOG_LEVEL=info